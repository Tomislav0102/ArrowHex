  startBubbleTexts:
  - characterType: 1
    text: You really think you can stop me with that toy?
  - characterType: 0
    text: "Funny, it\u2019s the last thing a lot of people saw."
  - characterType: 1
    text: "You should\u2019ve stayed in bed."
  - characterType: 1
    text: This is my territory!
  - characterType: 0
    text: "Then you should\u2019ve defended it better."
  - characterType: 1
    text: "I\u2019ll crush you like the others."
  - characterType: 0
    text: "Go ahead. I don\u2019t break easy."
